{
  "name": "simple-agent-orchestrator",
  "version": "0.1.0",
  "description": "A small TypeScript framework for routing channel events into durable agent sessions.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "simple-agent-orchestrator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/set-cli-executable.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "pack:local": "npm pack",
    "release:check": "node scripts/release-check.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.29",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
